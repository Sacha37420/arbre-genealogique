# ── Adresses ─────────────────────────────────────────────────────
PORT_BACKEND=8090
BACKEND_URL=http://localhost:8090
PORT_FRONTEND=4208
FRONTEND_URL=http://localhost:4208

# ── Base de données ──────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=devdb
DB_SCHEMA=arbre_genealogique
DB_USER=devuser
DB_PASSWORD=devpassword

# ── Django ───────────────────────────────────────────────────────
SECRET_KEY=REDACTED-SECRET-ROTATED
DEBUG=False
ALLOWED_HOSTS=*

# ── Reverse proxy (Caddy) ────────────────────────────────────────
SCRIPT_NAME=/arbre-genealogique-api

# ── SSO Keycloak ─────────────────────────────────────────────────
KEYCLOAK_CLIENT_ID=arbre-genealogique
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/ssolab
# Client public (SPA Angular) — Keycloak → Clients → arbre-genealogique → Access type : Public
# Valid redirect URIs : http://localhost:4208/*

# ── URLs (propagées automatiquement par reset_url.sh) ────────────
PORT_KEYCLOAK=8080
SERVER_URL_LAN=http://192.168.1.X
SERVER_URL_WAN=http://VOTRE_IP_WAN
KEYCLOAK_URL=http://192.168.1.X:8080
KEYCLOAK_PUBLIC_URL=http://VOTRE_IP_WAN:8080

# ── HTTPS / Caddy ─────────────────────────────────────────────────────────────
DOMAIN=CHANGE_ME
